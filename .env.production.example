# Supabase
DB_URL=jdbc:postgresql://YOUR_SUPABASE_HOST:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=replace-me
DB_DRIVER=org.postgresql.Driver

# Security
JWT_SECRET_KEY=replace-with-long-random-secret
COOKIE_DOMAIN=app.example.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
COOKIE_MAX_AGE=86400

# App URL / CORS
APP_FRONTEND_BASE_URL=https://app.example.com
CORS_ALLOW_ORIGINS=https://app.example.com
STARWORKS_FRONTEND_PORT=80

# File storage: Supabase Storage public bucket via S3-compatible API
FILE_STORAGE_MODE=s3
FILE_STORAGE_URL=/starworks_medias
# Only used when FILE_STORAGE_MODE=local
FILE_STORAGE_PATH=file:/data/starworks_medias/
AWS_ACCESS_KEY=replace-me
AWS_SECRET_KEY=replace-me
AWS_REGION=YOUR_SUPABASE_PROJECT_REGION
AWS_BUCKET=starworks-files
AWS_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
AWS_PUBLIC_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/starworks-files
AWS_PATH_STYLE_ACCESS=true

# Temporary local fallback on Cloudflare Containers (not recommended)
# FILE_STORAGE_MODE=local
# FILE_STORAGE_PATH=file:/data/starworks_medias/

# AI placeholders
SPRING_AI_VERTEX_AI_GEMINI_PROJECT_ID=replace-me
SPRING_AI_VERTEX_AI_GEMINI_LOCATION=us-central1
SPRING_AI_VERTEX_AI_EMBEDDING_PROJECT_ID=replace-me
SPRING_AI_VERTEX_AI_EMBEDDING_LOCATION=us-central1

# Logging
APP_LOG_LEVEL=info
REQUEST_MAPPING_LOG_LEVEL=warn
SPRING_VIEW_LOG_LEVEL=warn
SECURITY_LOG_LEVEL=info
SPRING_AI_LOG_LEVEL=warn
