# Use the Supabase transaction pooler on 6543 for the current Cloudflare deploy path.
DB_URL=jdbc:postgresql://YOUR_SUPABASE_HOST:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres
DB_PASSWORD=replace-me
JWT_SECRET_KEY=replace-with-long-random-secret
APP_FRONTEND_BASE_URL=https://modulearning02-api.<your-workers-subdomain>.workers.dev
CORS_ALLOW_ORIGINS=https://modulearning02-api.<your-workers-subdomain>.workers.dev
COOKIE_DOMAIN=
SIGNUP_TURNSTILE_ENABLED=false
SIGNUP_TURNSTILE_SITE_KEY=
SIGNUP_TURNSTILE_SECRET_KEY=
SIGNUP_RATE_LIMIT_IP_MAX_ATTEMPTS=10
SIGNUP_RATE_LIMIT_IP_WINDOW_SECONDS=600
SIGNUP_RATE_LIMIT_EMAIL_MAX_ATTEMPTS=5
SIGNUP_RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600
SIGNUP_RATE_LIMIT_SLUG_MAX_ATTEMPTS=5
SIGNUP_RATE_LIMIT_SLUG_WINDOW_SECONDS=3600
# Keep FILE_STORAGE_MODE=s3. Supabase Storage works through the existing S3-compatible path.
AWS_ACCESS_KEY=replace-me
AWS_SECRET_KEY=replace-me
# AWS_REGION is managed in wrangler.jsonc for deployed Workers.
AWS_REGION=YOUR_SUPABASE_PROJECT_REGION
AWS_BUCKET=starworks-files
AWS_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
AWS_PUBLIC_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/starworks-files
APP_JOBS_BOARD_WORKSPACE_ENABLED=false
APP_JOBS_ATTENDANCE_ENABLED=false
SPRING_AI_VERTEX_AI_GEMINI_PROJECT_ID=replace-me
SPRING_AI_VERTEX_AI_GEMINI_LOCATION=us-central1
SPRING_AI_VERTEX_AI_EMBEDDING_PROJECT_ID=replace-me
SPRING_AI_VERTEX_AI_EMBEDDING_LOCATION=us-central1
