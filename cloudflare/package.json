{
  "name": "starworks-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "npm --prefix ../frontend ci && npm --prefix ../frontend run build",
    "prepare:worker:assets": "node scripts/prepare-worker-assets.mjs",
    "build:frontend:worker": "npm run build:frontend && npm run prepare:worker:assets",
    "check": "node --check src/index.js",
    "dev": "wrangler dev",
    "deploy": "npm run build:frontend:worker && wrangler deploy",
    "deploy:pages": "npm run build:frontend && wrangler pages deploy ../frontend/dist --project-name modulearning02",
    "secrets:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-secrets.ps1",
    "seed:demo": "node scripts/seed-demo-data.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:attendance": "node scripts/smoke-attendance.mjs",
    "smoke:demo-users": "node scripts/smoke-demo-users.mjs",
    "smoke:all": "node scripts/smoke-suite.mjs"
  },
  "dependencies": {
    "@cloudflare/containers": "0.1.1"
  },
  "devDependencies": {
    "wrangler": "4.71.0"
  }
}
